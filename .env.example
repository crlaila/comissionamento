# Variáveis de ambiente do projeto.
# Copie este arquivo para .env e preencha os valores reais.
#
# NUNCA commite o .env com senhas reais — use .env.example como template.

# Banco de dados
DATABASE_URL=postgres://comissionamento:comissionamento@localhost:5433/comissionamento?sslmode=disable

# Servidor
PORT=8080

# JWT — chave secreta para assinar tokens.
# Em produção, use uma string longa e aleatória.
JWT_SECRET=mude-isso-em-producao

# Hinova — credenciais da API do sistema de associados.
HINOVA_API_TOKEN=sua-chave-aqui
HINOVA_API_URL=https://api.hinova.com.br/api/sga/v2

# Sync — intervalo de polling em minutos.
SYNC_INTERVAL=5
